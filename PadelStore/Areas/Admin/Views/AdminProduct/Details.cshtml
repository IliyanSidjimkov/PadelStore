@using PadelStore.ViewModels.Admin
@model ProductDetailsViewModel

<div class="container mt-4">

    <div class="row">

        <!-- IMAGE -->
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow" />
        </div>

        <!-- INFO -->
        <div class="col-md-6">

            <h2>@Model.ProductName</h2>

            <p class="text-muted">@Model.ProductDescription</p>

            <p>
                <strong>Category:</strong>
                <span class="badge bg-secondary">@Model.CategoryName</span>
            </p>

            <p>
                <strong>Brand:</strong>
                <span class="badge bg-dark">@Model.BrandName</span>
            </p>

            <h4 class="mt-3">@Model.Price.ToString("C")</h4>

            <!-- ACTION BUTTONS -->
            <div class="mt-4 d-flex gap-2">

                <!-- EDIT -->
                <a asp-area="Admin"
                       asp-controller="AdminProduct"
                       asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-warning">
                    ✏️ Edit
                </a>

                <!-- DELETE -->
                <form method="post"
                      asp-area="Admin"
                      asp-controller="AdminProduct"
                      asp-action="Delete">

                    <input type="hidden" name="id" value="@Model.Id" />

                    <button type="submit"
                            class="btn btn-danger"
                            onclick="return confirm('Are you sure you want to delete this product?')">
                        🗑 Delete
                    </button>
                </form>

                <!-- BACK -->
                <a asp-area="Admin"
                       asp-controller="AdminProduct"
                       asp-action="Index"
                       class="btn btn-secondary">
                    Back
                </a>

            </div>

        </div>

    </div>

</div>