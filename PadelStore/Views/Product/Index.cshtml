@using PadelStore.ViewModels.Admin
@model IEnumerable<ProductAllViewModel>

<h2 class="mb-4">Products 🛍️</h2>

<div class="row">

    @foreach (var p in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card h-100 shadow-sm">

                <img src="@p.ImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" />

                <div class="card-body text-center">
                    <h5>@p.ProductName</h5>
                    <p class="text-muted">@p.CategoryName</p>

                    <h6>@p.ProductPrice.ToString("C")</h6>

                    <a asp-action="Details" asp-route-id="@p.Id"
                           class="btn btn-outline-dark w-100 mt-2">
                        View Details
                    </a>
                </div>

            </div>
        </div>
    }

</div>