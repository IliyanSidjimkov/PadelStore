@using PadelStore.ViewModels.Admin
@model ProductDetailsViewModel

<div class="row">

    <div class="col-md-6">
        <img src="@Model.ImageUrl" class="img-fluid rounded" />
    </div>

    <div class="col-md-6">

        <h2>@Model.ProductName</h2>

        <p class="text-muted">@Model.ProductDescription</p>

        <p>
            <strong>Category:</strong>
            <span class="badge bg-secondary">@Model.CategoryName</span>
        </p>

        <p>
            <strong>Brand:</strong>
            <span class="badge bg-dark">@Model.BrandName</span>
        </p>

        <h4 class="mt-3">@Model.Price.ToString("C")</h4>

        <form asp-controller="Cart" asp-action="Add" method="post">
            <input type="hidden" name="productId" value="@Model.Id" />
            <button class="btn btn-success mt-3">
                Add to Cart
            </button>
        </form>

    </div>

</div>