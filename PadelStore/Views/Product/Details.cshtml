@using PadelStore.ViewModels
@using PadelStore.ViewModels.Admin
@using System.Security.Claims
@model ProductDetailsViewModel

<div class="row">

    <div class="col-md-6">
        <img src="@Model.ImageUrl" class="img-fluid rounded" />
    </div>

    <div class="col-md-6">

        <h2>@Model.ProductName</h2>

        <p class="text-muted">@Model.ProductDescription</p>

        <p>
            <strong>Category:</strong>
            <span class="badge bg-secondary">@Model.CategoryName</span>
        </p>

        <p>
            <strong>Brand:</strong>
            <span class="badge bg-dark">@Model.BrandName</span>
        </p>
        <hr />

        <h4 class="mt-4">Reviews</h4>

        @foreach (ReviewViewModel review in Model.Reviews)
        {
            <div class="border p-2 mb-2 rounded">

                <strong>@review.UserEmail</strong>
                <span class="text-warning">(@review.Rating ⭐)</span>

                <p>@review.Comment</p>

                @if (User.Identity!.IsAuthenticated &&
                            (User.IsInRole("Admin") || review.UserId.ToString() == User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier)))
                {
                    <a asp-controller="Review"
                           asp-action="Delete"
                           asp-route-id="@review.Id"
                           asp-route-productId="@Model.Id"
                           class="btn btn-sm btn-danger">
                        Delete
                    </a>
                }

            </div>
        }

        <h4 class="mt-3">@Model.Price.ToString("C")</h4>
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <form asp-controller="Cart" asp-action="Add" method="post">
                <input type="hidden" name="productId" value="@Model.Id" />
                <button class="btn btn-success mt-3">
                    Add to Cart
                </button>
            </form>
        }
        

    </div>
    @if (User.Identity!.IsAuthenticated)
    {
        <form asp-controller="Review" asp-action="Add" method="post" class="mt-4">

            <input type="hidden" name="ProductId" value="@Model.Id" />

            <div class="mb-2">
                <textarea name="Comment" class="form-control" placeholder="Write review..."></textarea>
            </div>

            <div class="mb-2">
                <input type="number" name="Rating" min="1" max="5" class="form-control" />
            </div>

            <button class="btn btn-primary">Add Review</button>
        </form>
    }

</div>