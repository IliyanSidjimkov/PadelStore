@{
    ViewData["Title"] = "Home";
    string? fullName = ViewBag.FullName;
}

<div class="container text-center" style="margin-top:100px;">

    <!-- TITLE -->
    <h1 class="display-4 fw-bold text-primary mb-3">
        🎾 PadelStore
    </h1>

    <p class="text-muted mb-4">
        Your one-stop shop for everything padel
    </p>

    <!-- USER -->
    @if (User.Identity!.IsAuthenticated && fullName != null)
    {
        <h5 class="mb-4">
            Welcome back, <strong>@fullName</strong> 👋
        </h5>
    }

    <!-- AUTH -->
    <div class="mb-5">

        @if (!User.Identity!.IsAuthenticated)
        {
            <a asp-area="Identity" asp-page="/Account/Login"
                   class="btn btn-outline-primary me-2 px-4">
                Login
            </a>

            <a asp-area="Identity" asp-page="/Account/Register"
                   class="btn btn-primary px-4">
                Register
            </a>
        }
        else
        {
            <form asp-area="Identity"
                  asp-page="/Account/Logout"
                  method="post"
                  class="d-inline">

                <button class="btn btn-danger px-4">
                    Logout
                </button>
            </form>
        }

    </div>

    <!-- MAIN BUTTONS -->
    <div class="d-flex justify-content-center gap-3 flex-wrap">

       

        @if (User.IsInRole("Admin"))
        {
            <a asp-area="Admin"
                   asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-dark px-4 py-2">
                👑 Admin Panel
            </a>
        }
        else
        {
            <a asp-controller="Product" asp-action="Index"
                   class="btn btn-primary px-4 py-2">
                Browse Products
            </a>

            @if (User.Identity.IsAuthenticated)
            {
                <a asp-controller="Cart" asp-action="Index"
                       class="btn btn-success px-4 py-2">
                    My Cart
                </a>

                <a asp-controller="Order" asp-action="MyOrders"
                       class="btn btn-warning px-4 py-2">
                    My Orders
                </a>
            }
        }

    </div>

    <!-- FOOTER TEXT -->
    <div class="mt-5 text-muted">
        <p>Discover top-quality padel equipment from the best brands.</p>
        <p>Fast delivery • Secure checkout • Best prices</p>
    </div>

</div>